<?xml version="1.0" encoding="UTF-8"?>
<application-bnd xmlns="http://websphere.ibm.com/xml/ns/javaee"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="http://websphere.ibm.com/xml/ns/javaee
                 http://websphere.ibm.com/xml/ns/javaee/ibm-application-bnd_1_2.xsd"
                 version="1.2">

  <!-- Map application security roles to WAS user registry entries -->
  <!-- In Phase 5 these will map to LDAP groups -->

  <security-role name="CUSTOMER">
    <special-subject type="ALL_AUTHENTICATED_USERS"/>
  </security-role>

  <security-role name="TELLER">
    <user name="teller1"/>
    <user name="teller2"/>
  </security-role>

  <security-role name="ADMIN">
    <user name="wasadmin"/>
  </security-role>

  <security-role name="AUDITOR">
    <user name="auditor1"/>
  </security-role>

</application-bnd>
