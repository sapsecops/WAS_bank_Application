<?xml version="1.0" encoding="UTF-8"?>
<ejb-jar xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/ejb-jar_3_2.xsd"
         version="3.2">

  <display-name>BankingEJB</display-name>
  <description>Banking EJB module containing session beans</description>

  <enterprise-beans>

    <session>
      <ejb-name>CustomerServiceBean</ejb-name>
      <ejb-class>com.banking.ejb.CustomerServiceBean</ejb-class>
      <session-type>Stateless</session-type>
      <transaction-type>Container</transaction-type>
      <resource-ref>
        <res-ref-name>jdbc/BankingDS</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
      </resource-ref>
    </session>

    <session>
      <ejb-name>AccountServiceBean</ejb-name>
      <ejb-class>com.banking.ejb.AccountServiceBean</ejb-class>
      <session-type>Stateless</session-type>
      <transaction-type>Container</transaction-type>
      <resource-ref>
        <res-ref-name>jdbc/BankingDS</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
      </resource-ref>
    </session>

    <session>
      <ejb-name>FundTransferBean</ejb-name>
      <ejb-class>com.banking.ejb.FundTransferBean</ejb-class>
      <session-type>Stateless</session-type>
      <transaction-type>Container</transaction-type>
    </session>

  </enterprise-beans>

  <assembly-descriptor>
    <container-transaction>
      <method>
        <ejb-name>FundTransferBean</ejb-name>
        <method-name>*</method-name>
      </method>
      <trans-attribute>Required</trans-attribute>
    </container-transaction>

    <container-transaction>
      <method>
        <ejb-name>AccountServiceBean</ejb-name>
        <method-name>*</method-name>
      </method>
      <trans-attribute>Required</trans-attribute>
    </container-transaction>

    <container-transaction>
      <method>
        <ejb-name>CustomerServiceBean</ejb-name>
        <method-name>find*</method-name>
      </method>
      <trans-attribute>Supports</trans-attribute>
    </container-transaction>

    <security-role>
      <role-name>TELLER</role-name>
    </security-role>
    <security-role>
      <role-name>ADMIN</role-name>
    </security-role>

    <method-permission>
      <role-name>TELLER</role-name>
      <role-name>ADMIN</role-name>
      <method>
        <ejb-name>FundTransferBean</ejb-name>
        <method-name>*</method-name>
      </method>
    </method-permission>

  </assembly-descriptor>

</ejb-jar>
