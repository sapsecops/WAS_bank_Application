<?xml version="1.0" encoding="UTF-8"?>
<ejb-jar-bnd xmlns="http://websphere.ibm.com/xml/ns/javaee"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://websphere.ibm.com/xml/ns/javaee
             http://websphere.ibm.com/xml/ns/javaee/ibm-ejb-jar-bnd_1_2.xsd"
             version="1.2">

  <session name="CustomerServiceBean">
    <interface class="com.banking.ejb.CustomerServiceBean"
               binding-name="ejb/CustomerServiceBean"/>
    <resource-ref name="jdbc/BankingDS"
                  binding-name="jdbc/BankingDS"/>
  </session>

  <session name="AccountServiceBean">
    <interface class="com.banking.ejb.AccountServiceBean"
               binding-name="ejb/AccountServiceBean"/>
    <resource-ref name="jdbc/BankingDS"
                  binding-name="jdbc/BankingDS"/>
  </session>

  <session name="FundTransferBean">
    <interface class="com.banking.ejb.FundTransferBean"
               binding-name="ejb/FundTransferBean"/>
  </session>

</ejb-jar-bnd>
