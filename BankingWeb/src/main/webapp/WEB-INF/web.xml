<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

  <display-name>BankingWeb</display-name>
  <description>Banking Application Web Module</description>

  <!-- Session timeout: 30 minutes -->
  <session-config>
    <session-timeout>30</session-timeout>
    <cookie-config>
      <http-only>true</http-only>
      <secure>true</secure>
    </cookie-config>
    <tracking-mode>COOKIE</tracking-mode>
  </session-config>

  <!-- JDBC DataSource reference — resolved via JNDI in WAS -->
  <resource-ref>
    <description>Banking PostgreSQL DataSource</description>
    <res-ref-name>jdbc/BankingDS</res-ref-name>
    <res-type>javax.sql.DataSource</res-type>
    <res-auth>Container</res-auth>
    <res-sharing-scope>Shareable</res-sharing-scope>
  </resource-ref>

  <!-- EJB references -->
  <ejb-local-ref>
    <ejb-ref-name>ejb/CustomerServiceBean</ejb-ref-name>
    <ejb-ref-type>Session</ejb-ref-type>
    <local>com.banking.ejb.CustomerServiceBean</local>
    <ejb-link>CustomerServiceBean</ejb-link>
  </ejb-local-ref>

  <ejb-local-ref>
    <ejb-ref-name>ejb/AccountServiceBean</ejb-ref-name>
    <ejb-ref-type>Session</ejb-ref-type>
    <local>com.banking.ejb.AccountServiceBean</local>
    <ejb-link>AccountServiceBean</ejb-link>
  </ejb-local-ref>

  <ejb-local-ref>
    <ejb-ref-name>ejb/FundTransferBean</ejb-ref-name>
    <ejb-ref-type>Session</ejb-ref-type>
    <local>com.banking.ejb.FundTransferBean</local>
    <ejb-link>FundTransferBean</ejb-link>
  </ejb-local-ref>

  <!-- Security roles -->
  <security-role><role-name>CUSTOMER</role-name></security-role>
  <security-role><role-name>TELLER</role-name></security-role>
  <security-role><role-name>ADMIN</role-name></security-role>
  <security-role><role-name>AUDITOR</role-name></security-role>

  <!-- Protect all banking API endpoints -->
  <security-constraint>
    <web-resource-collection>
      <web-resource-name>Banking API</web-resource-name>
      <url-pattern>/api/*</url-pattern>
    </web-resource-collection>
    <auth-constraint>
      <role-name>CUSTOMER</role-name>
      <role-name>TELLER</role-name>
      <role-name>ADMIN</role-name>
    </auth-constraint>
    <user-data-constraint>
      <transport-guarantee>CONFIDENTIAL</transport-guarantee>
    </user-data-constraint>
  </security-constraint>

  <login-config>
    <auth-method>FORM</auth-method>
    <realm-name>BankingRealm</realm-name>
    <form-login-config>
      <form-login-page>/login.jsp</form-login-page>
      <form-error-page>/login-error.jsp</form-error-page>
    </form-login-config>
  </login-config>

  <!-- Welcome page -->
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <!-- Custom error pages -->
  <error-page>
    <error-code>404</error-code>
    <location>/error/404.jsp</location>
  </error-page>
  <error-page>
    <error-code>500</error-code>
    <location>/error/500.jsp</location>
  </error-page>

</web-app>
